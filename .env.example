# Copy this file to .env and fill in your local Home Assistant details.
# Never commit the real .env file — it contains a token that can control
# every device Home Assistant knows about.

# Local URL of your Home Assistant instance, e.g. http://homeassistant.local:8123
VITE_HA_BASE_URL=

# Settings > People and Zones > Long-Lived Access Tokens > Create Token
VITE_HA_TOKEN=
